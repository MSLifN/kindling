# Copy this file to .env and fill in the values you need for your local demo.
# Both samples auto-load this file via python-dotenv at startup.

# hello-foundry-py (direct Azure OpenAI call with a key)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=

# hello-agent-py (Foundry agent reference via Entra ID)
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_AGENT_NAME=

# Optional: populated automatically when you deploy with `azd up`.
# Uncomment to wire OpenTelemetry / Application Insights into your demo.
# APPLICATIONINSIGHTS_CONNECTION_STRING=
